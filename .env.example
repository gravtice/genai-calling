# Copy this file to `.env.local` and fill in what you need.
# Do NOT commit `.env.local`.
#
# Load priority (high -> low):
#   .env.local > .env.production > .env.development > .env.test > ~/.genai-calling/.env
#
# Note: process environment variables win over `.env.*` (SDK uses `os.environ.setdefault()`).
# Recommended prefix: `GENAI_CALLING_*`.
#
# --------------------
# Common
# --------------------

# Default timeout budget in milliseconds.
GENAI_CALLING_TIMEOUT_MS=120000

# Hard limit for URL downloads (used by CLI/demo helpers).
GENAI_CALLING_URL_DOWNLOAD_MAX_BYTES=134217728

# Allow downloading private/loopback URLs (SSRF protection switch). Values: 1/true/yes.
# GENAI_CALLING_ALLOW_PRIVATE_URLS=1

# Internal transport marker. MCP server forces `mcp` (also accepts `sse`).
# GENAI_CALLING_TRANSPORT=

# --------------------
# Providers (pick what you use)
# --------------------

# OpenAI
GENAI_CALLING_OPENAI_API_KEY=
OPENAI_API_KEY=

# Google AI Studio (Gemini Developer API)
GENAI_CALLING_GOOGLE_API_KEY=
GOOGLE_API_KEY=

# Anthropic
GENAI_CALLING_ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY=

# Aliyun (DashScope / 百炼)
GENAI_CALLING_ALIYUN_API_KEY=
ALIYUN_API_KEY=
ALIYUN_OAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Volcengine Ark / 豆包
GENAI_CALLING_VOLCENGINE_API_KEY=
VOLCENGINE_API_KEY=
VOLCENGINE_OAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Tuzi (兔子 API)
TUZI_BASE_URL=https://api.tu-zi.com
# Optional overrides (defaults are derived from `TUZI_BASE_URL`):
# TUZI_OAI_BASE_URL=https://api.tu-zi.com/v1
# TUZI_GOOGLE_BASE_URL=https://api.tu-zi.com
# TUZI_ANTHROPIC_BASE_URL=https://api.tu-zi.com
GENAI_CALLING_TUZI_WEB_API_KEY=
TUZI_WEB_API_KEY=
GENAI_CALLING_TUZI_OPENAI_API_KEY=
TUZI_OPENAI_API_KEY=
GENAI_CALLING_TUZI_GOOGLE_API_KEY=
TUZI_GOOGLE_API_KEY=
GENAI_CALLING_TUZI_ANTHROPIC_API_KEY=
TUZI_ANTHROPIC_API_KEY=

# --------------------
# MCP Server (optional)
# --------------------

GENAI_CALLING_MCP_HOST=127.0.0.1
GENAI_CALLING_MCP_PORT=6001
GENAI_CALLING_MCP_PUBLIC_BASE_URL=
# GENAI_CALLING_MCP_BEARER_TOKEN=
# GENAI_CALLING_MCP_TOKEN_RULES=token1: [openai google]; token2: [openai:gpt-4o-mini]
